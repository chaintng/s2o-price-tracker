    "version": "0.2.0",
    "configurations": [
        {
            "command": "npm run local",
            "name": "Run Fetcher dev",
            "request": "launch",
            "type": "node-terminal",
            "envFile": "${workspaceFolder}/fetcher/.env",
            "cwd": "${workspaceFolder}/fetcher/"
        },
        {
            "command": "npm run dev",
            "name": "Run Viewer dev",
            "request": "launch",
            "type": "node-terminal",
            "envFile": "${workspaceFolder}/viewer/.env",
            "cwd": "${workspaceFolder}/viewer/"
        }
    ]
}
